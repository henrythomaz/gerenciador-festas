<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contrato #{{contrato.id}}</title>
  <style>
    /* Inclui o CSS inline para o PDF */
    {{> contract.css}}
  </style>
</head>
<body>
  <div class="contract-wrapper">
    <!-- Cabeçalho -->
    <header class="header">
      <h1>CONTRATO DE LOCAÇÃO DE FESTAS</h1>
      <p class="subtitle">Nº {{contrato.id}}</p>
    </header>

    <!-- Dados do Contrato -->
    <section class="section">
      <h2>Dados do Contrato</h2>
      <p><strong>Data de Início:</strong> {{formatDate contrato.data_inicio}}</p>
      <p><strong>Data de Término:</strong> {{formatDate contrato.data_fim}}</p>
      <p><strong>Valor Total:</strong> R$ {{formatCurrency contrato.valor_total}}</p>
      <p><strong>Status:</strong> {{contrato.status}}</p>
      {{#if contrato.observacoes}}
        <p><strong>Observações:</strong> {{contrato.observacoes}}</p>
      {{/if}}
    </section>

    <!-- Cliente -->
    <section class="section">
      <h2>Cliente</h2>
      <p><strong>Nome:</strong> {{cliente.nome}}</p>
      <p><strong>CPF:</strong> {{cliente.cpf}}</p>
      <p><strong>Telefone:</strong> {{cliente.telefone}}</p>
      <p><strong>Email:</strong> {{cliente.email}}</p>
    </section>

    <!-- Itens do Contrato -->
    <section class="section">
      <h2>Itens Locados</h2>
      <table class="items-table">
        <thead>
          <tr>
            <th>Imagem</th>
            <th>Produto</th>
            <th>Quantidade</th>
            <th>Preço Unitário</th>
            <th>Subtotal</th>
          </tr>
        </thead>
        <tbody>
          {{#each itens}}
            <tr>
              <td class="text-center">
                {{#if imagem_base64}}
                  <img src="{{imagem_base64}}" alt="{{produto_nome}}" class="product-image" />
                {{else}}
                  <span style="color:#999;">Sem imagem</span>
                {{/if}}
              </td>
              <td>{{produto_nome}}</td>
              <td class="text-center">{{quantidade}}</td>
              <td class="text-right">R$ {{formatCurrency preco_unitario}}</td>
              <td class="text-right">R$ {{formatCurrency subtotal}}</td>
            </tr>
          {{/each}}
        </tbody>
        <tfoot>
          <tr>
            <td colspan="4" class="text-right"><strong>Total do Contrato</strong></td>
            <td class="text-right"><strong>R$ {{formatCurrency contrato.valor_total}}</strong></td>
          </tr>
        </tfoot>
      </table>
    </section>

    <!-- Responsável -->
    <section class="section">
      <h2>Responsável pelo Cadastro</h2>
      <p><strong>Nome:</strong> {{usuario.nome}}</p>
      <p><strong>Email:</strong> {{usuario.email}}</p>
    </section>

    <!-- Assinaturas -->
    <section class="signatures">
      <div class="signature-box">
        <div class="signature-line"></div>
        <p class="signature-label">Cliente</p>
      </div>
      <div class="signature-box">
        <div class="signature-line"></div>
        <p class="signature-label">Responsável da Empresa</p>
      </div>
    </section>

    <!-- Rodapé -->
    <footer class="footer">
      <p>Documento gerado em {{data_geracao}} - Sistema Gerenciador de Festas</p>
    </footer>
  </div>
</body>
</html>
